# Copy to frontend/.env.local for local development

# Solana cluster: mainnet-beta | devnet | testnet | localnet
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Optional: custom RPC (recommended for production)
NEXT_PUBLIC_SOLANA_RPC_URL=

# RWA program (deploy your Anchor program and paste the program id)
NEXT_PUBLIC_RWA_PROGRAM_ID=

# SPL mint authority / vault addresses used by your on-chain program (optional UI hints)
NEXT_PUBLIC_RWA_VAULT=

# Jupiter API (optional; for swap quotes on mainnet-beta / devnet)
NEXT_PUBLIC_JUPITER_API_URL=https://quote-api.jup.ag/v6

# App metadata
NEXT_PUBLIC_APP_NAME=RWA Solana
